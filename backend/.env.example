NODE_ENV=development
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://127.0.0.1:3000
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=1 minute
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_ADMIN_USER=root
MYSQL_ADMIN_PASSWORD=
MYSQL_CONNECTION_LIMIT=5
MYSQLDUMP_BINARY=mysqldump
MYSQL_CLIENT_BINARY=mysql
DATABASE_BACKUP_DIR=C:/nhitvps/backups/databases
DATABASE_BACKUP_TIMEOUT_MS=600000
DATABASE_RESTORE_TIMEOUT_MS=600000
DATABASE_BACKUP_MAX_BYTES=268435456
UFW_BINARY=ufw
APT_GET_BINARY=apt-get
DPKG_BINARY=dpkg
MONITOR_DISK_PATHS=.
DOCKER_SOCKET_PATH=/var/run/docker.sock

# Development only: when NODE_ENV is not production, the in-memory auth adapter seeds:
# username=admin
# password=P@ssw0rd12345
