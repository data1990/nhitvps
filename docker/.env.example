BACKEND_PORT=8080
FRONTEND_PORT=3000

# Change both values before production deploy. SESSION_COOKIE_SECRET must be at least 32 characters.
SESSION_COOKIE_SECRET=change-me-to-a-random-64-character-secret
MARIADB_ROOT_PASSWORD=change-me-to-a-strong-database-password
MARIADB_DATABASE=nhitvps

LOG_LEVEL=info
CORS_ORIGINS=https://panel.example.com
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW=1 minute

SESSION_COOKIE_NAME=nhitvps_session
SESSION_COOKIE_SECURE=true
SESSION_TTL_MINUTES=720
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-to-a-strong-admin-password

MYSQL_ADMIN_USER=root
MYSQL_CONNECTION_LIMIT=5
MYSQLDUMP_BINARY=mysqldump
MYSQL_CLIENT_BINARY=mysql
DATABASE_BACKUP_TIMEOUT_MS=600000
DATABASE_RESTORE_TIMEOUT_MS=600000
DATABASE_BACKUP_MAX_BYTES=268435456

NGINX_SITES_AVAILABLE_DIR=/etc/nginx/sites-available
NGINX_SITES_ENABLED_DIR=/etc/nginx/sites-enabled
NGINX_BACKUP_DIR=/var/lib/nhitvps/nginx/backups
NGINX_LOG_DIR=/var/log/nginx
NGINX_BINARY=nginx
SYSTEMCTL_BINARY=systemctl
CERTBOT_BINARY=certbot
UFW_BINARY=ufw
